AME &optional AUTO-CREATE-P)") (defalias '+workspace/restore-last-session #'doom/quickload-session) (autoload '+workspace/load "~/.config/emacs/sources/doom+/modules/ui/workspaces/autoload/workspaces" "Load a workspace and switch to it. If called with C-u, try to reload the\ncurrent workspace (by name) from session files.\n\n(fn NAME)" t) (autoload '+workspace/save "~/.config/emacs/sources/doom+/modules/ui/workspaces/autoload/workspaces" "Save the current workspace. If called with C-u, autosave the current\nworkspace.\n\n(fn NAME)" t) (autoload '+workspace/rename "~/.config/emacs/sources/doom+/modules/ui/workspaces/autoload/workspaces" "Rename the current workspace.\n\n(fn NEW-NAME)" t) (autoload '+workspace/kill "~/.config/emacs/sources/doom+/modules/ui/workspaces/autoload/workspaces" "Delete this workspace. If called with C-u, prompts you for the name of the\nworkspace to delete.\n\n(fn NAME)" t) (autoload '+workspace/delete "~/.config/emacs/sources/doom+/modules/ui/workspaces/autoload/workspaces" "Delete a saved workspace in `persp-save-dir'.\n\nCan only selete workspaces saved with `+workspace/save' or `+workspace-save'.\n\n(fn NAME)" t) (autoload '+workspace/kill-session "~/.config/emacs/sources/doom+/modules/ui/workspaces/autoload/workspaces" "Delete the current session, all workspaces, windows and their buffers.\n\n(fn &optional INTERACTIVE)" t) (autoload '+workspace/kill-session-and-quit "~/.config/emacs/sources/doom+/modules/ui/workspaces/autoload/workspaces" "Kill emacs without saving anything." t) (autoload '+workspace/new "~/.config/emacs/sources/doom+/modules/ui/workspaces/autoload/workspaces" "Create a new workspace named NAME. If CLONE-P is non-nil, clone the current\nworkspace, otherwise the new workspace is blank.\n\n(fn &optional NAME CLONE-P)" t) (autoload '+workspace/new-named "~/.config/emacs/sources/doom+/modules/ui/workspaces/autoload/workspaces" "Create a new workspace with a given NAME.\n\n(fn NAME)" t) (autoload '+workspace/switch-to "~/.co